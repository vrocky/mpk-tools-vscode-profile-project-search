<Window x:Class="VsCodeProfileProjectSearch.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="VS Code Project Picker Across Profile Containers"
        Width="980" Height="680"
        MinWidth="780" MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Background="#101522">

    <Window.Resources>
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Background" Value="#18213A"/>
            <Setter Property="Foreground" Value="#E3E9F8"/>
            <Setter Property="CaretBrush" Value="#5ED3F3"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#2A3B66"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <Grid>
                                <TextBlock x:Name="Placeholder"
                                           Text="Search by project path, profile, or container directory..."
                                           Foreground="#7386BA"
                                           Padding="{TemplateBinding Padding}"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False"
                                           Visibility="Collapsed"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Padding="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter TargetName="Placeholder" Property="Visibility" Value="Visible"/>
                            </Trigger>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#5ED3F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button">
            <Setter Property="Background" Value="#1E8FAA"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1E8FAA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="7"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#23A7C7"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#2A3B66"/>
                                <Setter Property="BorderBrush" Value="#2A3B66"/>
                                <Setter Property="Foreground" Value="#7E8FB8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ProjectRowButton" TargetType="Button">
            <Setter Property="Background" Value="#151E34"/>
            <Setter Property="Foreground" Value="#E3E9F8"/>
            <Setter Property="BorderBrush" Value="#2A3B66"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1A2849"/>
                                <Setter Property="BorderBrush" Value="#5ED3F3"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Project Picker Across VS Code Profile Containers"
                           FontSize="24" FontWeight="Bold" Foreground="#E3E9F8"/>
                <TextBlock x:Name="SubtitleText"
                           Margin="0,6,0,0"
                           Foreground="#8DA0D1"
                           FontSize="12"
                           Text="Loading profile container project index..."/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Style="{StaticResource PrimaryButton}"
                        Content="Settings"
                        Margin="0,4,12,0"
                        Click="Settings_Click"/>
                <CheckBox x:Name="IncludeMissingCheck"
                          Margin="0,8,12,0"
                          VerticalAlignment="Center"
                          Foreground="#9EB2E3"
                          Content="Include missing"
                          Click="IncludeMissingCheck_Click"/>
                <Button Style="{StaticResource PrimaryButton}"
                        Content="Refresh"
                        Margin="0,4,0,0"
                        Click="Refresh_Click"/>
            </StackPanel>
        </Grid>

        <TextBox x:Name="SearchBox"
                 Grid.Row="1"
                 Style="{StaticResource SearchBoxStyle}"
                 Margin="0,0,0,12"
                 TextChanged="SearchBox_TextChanged"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ProjectsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Style="{StaticResource ProjectRowButton}"
                                Tag="{Binding}"
                                IsEnabled="{Binding Exists}"
                                Click="OpenProject_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding ProjectPath}" Foreground="#E8EEFF" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Margin="0,4,0,0" Foreground="#8DA0D1" FontSize="11" TextTrimming="CharacterEllipsis">
                                        <Run Text="Recent: "/>
                                        <Run Text="{Binding TimelineLabel, Mode=OneWay}"/>
                                        <Run Text="  |  "/>
                                        <Run Text="Profile: "/>
                                        <Run Text="{Binding ProfileName}"/>
                                        <Run Text="  |  Container: "/>
                                        <Run Text="{Binding ProfileContainerDirectory}"/>
                                        <Run Text="  |  Kind: "/>
                                        <Run Text="{Binding Kind}"/>
                                        <Run Text="  |  Source: "/>
                                        <Run Text="{Binding Source}"/>
                                        <Run Text="  |  "/>
                                        <Run Text="{Binding ExistsLabel, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Margin="10,0,0,0"
                                        Background="#243660"
                                        CornerRadius="6"
                                        Padding="10,5"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="Open"
                                               Foreground="#D8E2FF"
                                               FontWeight="SemiBold"
                                               FontSize="11"/>
                                </Border>
                            </Grid>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock x:Name="StatusText"
                   Grid.Row="3"
                   Margin="0,10,0,0"
                   Foreground="#778ABF"
                   FontSize="11"
                   HorizontalAlignment="Center"/>
    </Grid>
</Window>
